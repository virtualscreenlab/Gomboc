Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "radial", " ", "function"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"r", "[", "\[Theta]_", "]"}], ":=", 
    RowBox[{"1.0", "+", 
     RowBox[{"0.20", " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "+", 
     RowBox[{"0.12", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"2.8", " ", "\[Theta]"}], "+", "0.5"}], "]"}]}], "+", 
     RowBox[{"0.08", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"4.5", " ", "\[Theta]"}], "]"}]}]}]}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"Create", " ", "the", " ", "polar", " ", "plot"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"polarPlot", "=", 
    RowBox[{"PolarPlot", "[", 
     RowBox[{
      RowBox[{"r", "[", "\[Theta]", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "0", ",", 
        RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Blue"}], "}"}]}], ",", 
      RowBox[{"AxesLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
      RowBox[{
      "PlotLabel", "\[Rule]", 
       "\"\<r(\[Theta]) = 1.0 + 0.20 sin \[Theta] + 0.12 sin(2.8\[Theta] + \
0.5) + 0.08 cos(4.5\[Theta])\>\""}], ",", 
      RowBox[{"LabelStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"14", ",", "Bold"}], "}"}]}], ",", 
      RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Create", " ", "a", " ", "filled", " ", "version", " ", 
     RowBox[{"(", 
      RowBox[{"solid", " ", "shape"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"filledShape", "=", 
    RowBox[{"PolarPlot", "[", 
     RowBox[{
      RowBox[{"r", "[", "\[Theta]", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "0", ",", 
        RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Blue"}], "}"}]}], ",", 
      RowBox[{"Filling", "\[Rule]", "Axis"}], ",", 
      RowBox[{"FillingStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"LightBlue", ",", 
         RowBox[{"Opacity", "[", "0.5", "]"}]}], "}"}]}], ",", 
      RowBox[{"AxesLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "\[Rule]", "\"\<Filled Polar Shape\>\""}], ",", 
      RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Create", " ", "a", " ", "parametric", " ", "representation", " ", "for", 
     " ", "more", " ", "control"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"parametricShape", "=", 
    RowBox[{"ParametricPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"r", "[", "\[Theta]", "]"}], " ", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
        RowBox[{
         RowBox[{"r", "[", "\[Theta]", "]"}], " ", 
         RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "0", ",", 
        RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Thick"}], "}"}]}], ",", 
      RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
      RowBox[{"AxesLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "\[Rule]", "\"\<Parametric Form\>\""}], ",", 
      RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Display", " ", "all", " ", "three", " ", "visualizations"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"GraphicsGrid", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"polarPlot", ",", "filledShape", ",", "parametricShape"}], 
       "}"}], "}"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "1200"}], ",", 
     RowBox[{"Spacings", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"20", ",", "0"}], "}"}]}]}], "]"}]}]}]], "Input",
